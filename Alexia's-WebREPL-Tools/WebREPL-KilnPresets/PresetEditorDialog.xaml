<Window x:Class="WebREPL_KilnPresets.PresetEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fire Preset Editor" Height="600" Width="1200"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Key (File Name):" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox x:Name="KeyTextBox" Grid.Row="0" Grid.Column="1" Margin="5"/>

            <TextBlock Text="Category:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
            <ComboBox x:Name="CategoryComboBox" Grid.Row="1" Grid.Column="1" Margin="5" IsEditable="True"/>

            <TextBlock Text="Name:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox x:Name="DescriptionTextBox" Grid.Row="2" Grid.Column="1" Margin="5"/>
        </Grid>

        <GroupBox Header="Fire Instructions" Grid.Row="1" Margin="0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <Button Content="Add Heat (H)" Click="AddHeat_Click" Width="100" Margin="0,0,5,0"/>
                        <Button Content="Add Ramp (R)" Click="AddRamp_Click" Width="100" Margin="0,0,5,0"/>
                        <Button Content="Add Drop (D)" Click="AddDown_Click" Width="100" Margin="0,0,5,0"/>
                        <Button Content="Add Soak (S)" Click="AddSoak_Click" Width="100" Margin="0,0,5,0"/>
                        <Button Content="Add Cool (C)" Click="AddCool_Click" Width="100" Margin="0,0,5,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="InstructionsGrid" 
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type" Binding="{Binding DisplayName}" IsReadOnly="True" Width="100"/>
                        <DataGridTemplateColumn Header="Target Temp (°C)" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}" 
                                             Visibility="{Binding ShowTarget, Converter={StaticResource BoolToVisConverter}}"
                                             BorderThickness="0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Duration" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" 
                                                Visibility="{Binding ShowDuration, Converter={StaticResource BoolToVisConverter}}">
                                        <TextBox Width="40" Margin="2" Text="{Binding Path=DurationHours, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="h" VerticalAlignment="Center" Margin="2"/>
                                        <TextBox Width="40" Margin="2" Text="{Binding Path=DurationMinutes, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="m" VerticalAlignment="Center" Margin="2"/>
                                        <TextBox Width="40" Margin="2" Text="{Binding Path=DurationSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="s" VerticalAlignment="Center" Margin="2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Actions" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="↑" Click="MoveUp_Click" Width="30" Margin="2" ToolTip="Move Up"/>
                                        <Button Content="↓" Click="MoveDown_Click" Width="30" Margin="2" ToolTip="Move Down"/>
                                        <Button Content="✕" Click="Delete_Click" Width="30" Margin="2" ToolTip="Delete"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                </Grid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="LightGray"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="5" Background="#F0F0F0">
                        <TextBlock Text="Fire Profile" FontWeight="Bold" FontSize="14" Margin="5"/>
                        <TextBlock x:Name="ProfileStatsText" Text="Total Time: 0h 0m" Margin="5,0,5,5" FontSize="11"/>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Margin="5">
                        <Canvas x:Name="ProfileCanvas" Background="White"/>
                    </Border>
                </Grid>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Click="Save_Click" Width="80" Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="Cancel" Click="Cancel_Click" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
