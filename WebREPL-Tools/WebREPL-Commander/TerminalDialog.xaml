<Window x:Class="WebREPL_Commander.TerminalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WebREPL Terminal" Height="500" Width="800" 
        WindowStartupLocation="CenterOwner"
        Background="#000080">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#008080"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#00FFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00A0A0"/>
                                <Setter Property="BorderBrush" Value="#00FFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#006060"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#404040"/>
                                <Setter Property="Foreground" Value="#808080"/>
                                <Setter Property="BorderBrush" Value="#606060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#00FFFF" BorderThickness="2" Background="Black">
            <ScrollViewer Name="scrollViewer" VerticalScrollBarVisibility="Auto">
                <TextBox Name="txtOutput" Background="Black" Foreground="#00FF00" 
                         FontFamily="Consolas" IsReadOnly="True" 
                         TextWrapping="Wrap" BorderThickness="0"
                         Padding="5"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text=">>>" Foreground="Yellow" FontWeight="Bold" 
                       FontFamily="Consolas" Margin="0,0,5,0" VerticalAlignment="Center"/>
            
            <TextBox Grid.Column="1" Name="txtCommand" Background="Black" Foreground="White" 
                     BorderBrush="#00FFFF" BorderThickness="2" Padding="5"
                     FontFamily="Consolas" KeyDown="TxtCommand_KeyDown"/>
            
            <Button Grid.Column="2" Name="btnSend" Content="Send" Width="80" Margin="10,0,0,0"
                    Click="BtnSend_Click"
                    Background="#008080" Foreground="White" BorderBrush="#00FFFF" FontWeight="Bold"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Clear" Width="100" Margin="5" Click="BtnClear_Click"
                    Background="#008080" Foreground="White" BorderBrush="#00FFFF" FontWeight="Bold"/>
            <Button Content="Interrupt (Ctrl+C)" Width="150" Margin="5" Click="BtnInterrupt_Click"
                    Background="#800000" Foreground="White" BorderBrush="#00FFFF" FontWeight="Bold"/>
            <Button Content="Close" Width="100" Margin="5" Click="BtnClose_Click"
                    Background="#008080" Foreground="White" BorderBrush="#00FFFF" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
