<Window x:Class="WebREPL_KilnPresets.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WebREPL_KilnPresets"
        mc:Ignorable="d"
        Title="Kiln Fire Preset Manager" Height="600" Width="1000"
        Icon="/KilnPresetIcon.ico"
        Loaded="Window_Loaded">
    <Window.Resources>
        <local:IsStringConverter x:Key="IsStringConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New Preset" Click="NewPreset_Click"/>
                <Separator/>
                <MenuItem Header="_Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Device" Visibility="Collapsed">
                <MenuItem Header="_Connect" Click="Connect_Click"/>
                <MenuItem Header="_Manage Hosts" Click="ManageHosts_Click"/>
                <Separator/>
                <MenuItem Header="_Refresh Remote" Click="RefreshRemote_Click" x:Name="RefreshMenuItem" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Preset Library" Grid.Column="0" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <Button Content="Refresh" Click="RefreshLocal_Click" Width="80" Margin="0,0,5,0"/>
                        <Button Content="Open Folder" Click="OpenLibraryFolder_Click" Width="80"/>
                    </StackPanel>

                    <TreeView Grid.Row="1" x:Name="LocalTreeView" 
                              MouseDoubleClick="LocalTreeView_DoubleClick"
                              MouseDown="LocalTreeView_MouseDown"
                              AllowDrop="True"
                              Drop="LocalTreeView_Drop"
                              DragOver="LocalTreeView_DragOver"
                              SelectedItemChanged="LocalTreeView_SelectionChanged"
                              Margin="5"
                              BorderThickness="1"
                              BorderBrush="#CCCCCC">
                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F0F0F0"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}, Converter={StaticResource IsStringConverter}}" Value="True">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#2C5AA0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.Resources>
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Push to Device" Click="PushToDevice_Click" Visibility="Collapsed"/>
                                <MenuItem Header="Edit" Click="EditPreset_Click"/>
                                <MenuItem Header="Save As Copy..." Click="SaveAsCopy_Click"/>
                                <Separator/>
                                <MenuItem Header="Delete" Click="DeletePreset_Click"/>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="LightGray"/>

            <GroupBox Header="Fire Profile Preview" Grid.Column="2" Margin="5" x:Name="PreviewPanel">
                <Grid>
                    <TextBlock x:Name="PreviewText" 
                               Text="Select a preset to preview its fire profile graph."
                               Margin="10"
                               FontSize="14"
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    <Canvas x:Name="GraphCanvas" 
                            Margin="10"
                            Visibility="Collapsed"
                            SizeChanged="GraphCanvas_SizeChanged"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>
                </Grid>
            </GroupBox>

            <!-- Device panel - hidden -->
            <GroupBox Header="Device (/presets)" Grid.Column="2" Margin="5" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock x:Name="StatusText" Text="Not Connected" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>

                    <TreeView Grid.Row="1" x:Name="RemoteTreeView"
                              MouseDoubleClick="RemoteTreeView_DoubleClick"
                              AllowDrop="True"
                              Drop="RemoteTreeView_Drop"
                              DragOver="RemoteTreeView_DragOver"
                              Margin="5"/>
                </Grid>
            </GroupBox>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusBarText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
